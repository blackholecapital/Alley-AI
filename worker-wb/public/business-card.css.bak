body{
font-family:sans-serif;
max-width:600px;
margin:auto;
padding:20px;
background:#111;
color:#fff;
}

button{
width:100%;
padding:16px;
margin:12px 0;
font-size:18px;
}

input{
width:100%;
padding:12px;
margin:8px 0;
font-size:16px;
box-sizing:border-box;
}

img{
width:100%;
margin:20px 0;
display:none;
border-radius:8px;
}
